{
  "name": "pdf-to-epub-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "cp -r node_modules/tinymce public/tinymce 2>/dev/null || true",
    "dev": "vite",
    "dev:full": "concurrently -n front,api -c cyan,yellow \"bun run dev\" \"bun run server:dev\"",
    "build": "tsc && vite build",
    "build:bun": "bun run scripts/build.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "bun server.js",
    "server:dev": "bun --watch server.js",
    "server:lt": "LANGUAGETOOL_URL=http://localhost:8010 bun --watch server.js",
    "languagetool": "bash scripts/start-languagetool.sh",
    "dev:lt": "concurrently -n lt,api,front -c magenta,yellow,cyan \"bun run languagetool\" \"bun run server:lt\" \"bun run dev\""
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.13.2",
    "concurrently": "^9.2.1",
    "dictionary-pt": "^4.0.0",
    "fflate": "^0.8.2",
    "file-saver": "^2.0.5",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.4.530",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-image-crop": "^11.0.10",
    "react-reader": "^2.0.15",
    "react-router-dom": "^7.12.0",
    "react-virtuoso": "^4.18.10",
    "sharp": "^0.34.5",
    "tinymce": "^8.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "bun-types": "^1.3.6",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
